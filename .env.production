# ==============================================================================
# 🚀 AUIP PLATFORM — PRODUCTION ENVIRONMENT TEMPLATE
# ==============================================================================
# Copy these into your Cloud Provider's Environment Variable settings.
# Do NOT commit the actual values to GitHub!

# --- CORE SETTINGS ---
DEBUG=False
DJANGO_SETTINGS_MODULE=auip_core.settings.production
DJANGO_SECRET_KEY=your_long_random_secret_key_here
ALLOWED_HOSTS=auip-api.onrender.com,yourdomain.com

# --- DATABASE (Supabase or Render DB) ---
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# --- CACHE & BROKER (Upstash Redis) ---
# Format: rediss://:PASSWORD@HOST:PORT/0
REDIS_URL=rediss://:default_password@your-endpoint.upstash.io:6379/0

# --- FRONTEND & CORS ---
# The URL where your Netlify app is hosted
FRONTEND_URL=https://auip.netlify.app
CORS_ALLOWED_ORIGINS=https://auip.netlify.app
CSRF_TRUSTED_ORIGINS=https://auip.netlify.app

# --- AI ENGINES ---
GEMINI_API_KEY=your_google_ai_key
GROQ_API_KEY=your_groq_key
# HF_TOKEN=your_hugging_face_token (optional)

# --- EMAIL (Optional) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your_email
# EMAIL_HOST_PASSWORD=your_app_password
